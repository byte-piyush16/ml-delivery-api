# Databricks Workspace URL (Model Serving endpoints ke liye)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com

# Personal Access Token (with permission to call serving endpoints)
DATABRICKS_TOKEN=your_personal_access_token

# SQL Warehouse Connection Details (for demand forecast)
DATABRICKS_SERVER_HOSTNAME=your-server-hostname
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id